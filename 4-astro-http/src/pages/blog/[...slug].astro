---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import LikeCounter from '../../components/likes/LikeCounter.svelte';
import LikeCounterAction from '../../components/likes/LikeCounterAction.svelte';

// Esta página se prerenderiza para que cada publicación de blog esté disponible como una página estática en el sitio. Esto mejora el rendimiento y la SEO, ya que las páginas se generan en tiempo de construcción y se sirven rápidamente a los usuarios.
export const prerender = true;

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data}>
	<!-- <LikeCounter postId={post.id} client:only="svelte" /> -->
	 <LikeCounterAction postId={post.id} client:only="svelte" />

	<Content />
</BlogPost>
