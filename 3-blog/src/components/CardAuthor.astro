---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content'

interface Props {
    author: CollectionEntry<'author'>;
}

const { author } = Astro.props;
console.log(author);

const { name, avatar, bio, github, twitter, linkedIn, subtitle } = author.data;

---

<div class="max-w-lg mx-auto my-10 bg-white/10 rounded-lg shadow-md p-5">
    <Image class={'aspect-square rounded-full mx-auto w-32'} src={avatar} alt={name}  quality={'low'} />
    
    <h2 class="text-center text-2xl font-semibold mt-3">{ name }</h2>
    <p class="text-center mt-1">{ subtitle }</p>
    <div class="flex justify-center mt-5">
        <a href="#" class="text-blue-500 hover:text-blue-700 mx-3"
            >Twitter: {twitter}</a
        >
        <a href={linkedIn} class="text-blue-500 hover:text-blue-700 mx-3"
            >LinkedIn</a
        >
        <a href={github} class="text-blue-500 hover:text-blue-700 mx-3"
            >GitHub</a
        >
    </div>
    <div class="mt-5">
        <h3 class="text-xl font-semibold">Bio</h3>
        <p class="mt-2">
            { bio }
        </p>

        <div class="flex justify-end">
            <a href={`/posts/${ author.id }`}>Leer más</a>
        </div>
    </div>
</div>